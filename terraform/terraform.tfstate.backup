      "mode": "managed",
      "type": "aws_cloudfront_function",
      "name": "apex_redirect",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "arn": "arn:aws:cloudfront::637423547432:function/brad-beltran-site-apex-redirect",
            "code": "function handler(event) {\n    var request = event.request;\n    var host = request.headers.host.value;\n\n    if (host === \"bradbeltran.com\") {\n        var response = {\n            statusCode: 301,\n            statusDescription: 'Moved Permanently',\n            headers: {\n                \"location\": { \"value\": \"https://www.bradbeltran.com$\"}\n            }\n        };\n        return response;\n    }\n",
